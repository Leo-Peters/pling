#!/usr/bin/env bash
#
# pling - Make the taskbar flash to signal a task is done.
#
# Works on:
#   - Windows Terminal (WSL2) — taskbar flashes orange
#   - GNOME / KDE / most X11 desktops — urgency hint + notify-send
#   - macOS Terminal / iTerm2 — dock bounce
#
# Usage:
#   pling                      # flash taskbar
#   long-task; pling           # flash when task finishes
#   pling -m "Build done"      # flash with a message (shown in notification)
#   pling -- make build        # run command, flash when it finishes
#
# Install:
#   cp pling /usr/local/bin/   (or anywhere on your PATH)
#
# AI agent integration: see the README for ready-to-paste snippets that wire
# pling into Claude Code, Aider, and Codex CLI as a finish-event hook.

set -euo pipefail

MESSAGE=""
SOUND=""

# Config file for persistent sound setting
PLING_CONFIG="${PLING_CONFIG:-$HOME/.config/pling/config}"

usage() {
    cat <<'EOF'
Usage: pling [options] [-- command [args...]]

Make the taskbar flash to signal a task is done.

Options:
  -m MSG            Notification message (default: "Task complete")
  -s FILE           Play a sound file (.wav, .mp3, .ogg)
  --set-sound FILE  Save a default sound so you never need -s again
  -h, --help        Show this help

Examples:
  make build; pling                   # flash after build
  pling -- make build                 # same thing
  pling -m "Tests passed"             # flash with custom message
  pling -s ~/sounds/done.wav          # flash + play sound
  pling --set-sound ~/sounds/done.wav # save as default sound

See the README for AI agent (Claude Code / Aider / Codex CLI) hook snippets.
EOF
    exit 0
}

while [[ $# -gt 0 ]]; do
    case "$1" in
        -m)             MESSAGE="$2"; shift 2 ;;
        -s)             SOUND="$2"; shift 2 ;;
        --set-sound)
            mkdir -p "$(dirname "$PLING_CONFIG")"
            echo "$2" > "$PLING_CONFIG"
            echo "Default sound saved: $2"
            exit 0
            ;;
        -h|--help)      usage ;;
        --)             shift; break ;;
        -*)             echo "pling: unknown option $1" >&2; exit 1 ;;
        *)              break ;;
    esac
done

: "${MESSAGE:=Task complete}"

# Load default sound from config if -s was not given
if [[ -z "$SOUND" && -f "$PLING_CONFIG" ]]; then
    SOUND="$(cat "$PLING_CONFIG")"
fi

# ─── Run wrapped command if provided ────────────────────────────────────────

CMD_EXIT=0
if [[ $# -gt 0 ]]; then
    "$@" || CMD_EXIT=$?
fi

# ─── Detect environment and flash the taskbar ──────────────────────────────

is_wsl() {
    [[ -f /proc/version ]] && grep -qi microsoft /proc/version
}

has_cmd() {
    command -v "$1" &>/dev/null
}

notified=false

# 1. WSL2: call FlashWindowEx via powershell — this is the actual Win32 API
#    that makes the taskbar button flash orange until you click the window.
if is_wsl && has_cmd powershell.exe; then
    powershell.exe -NoProfile -Command '
        Add-Type -TypeDefinition @"
using System;
using System.Runtime.InteropServices;

public struct FLASHWINFO {
    public uint cbSize;
    public IntPtr hwnd;
    public uint dwFlags;
    public uint uCount;
    public uint dwTimeout;
}

public class WindowFlash {
    [DllImport("user32.dll")]
    public static extern bool FlashWindowEx(ref FLASHWINFO pwfi);

    public static bool Flash(IntPtr hwnd) {
        if (hwnd == IntPtr.Zero) return false;
        FLASHWINFO fi = new FLASHWINFO();
        fi.cbSize = (uint)Marshal.SizeOf(typeof(FLASHWINFO));
        fi.hwnd = hwnd;
        fi.dwFlags = 3 | 12;
        fi.uCount = 0;
        fi.dwTimeout = 0;
        return FlashWindowEx(ref fi);
    }
}
"@
        # Find all Windows Terminal windows and flash them
        $wt = Get-Process WindowsTerminal -ErrorAction SilentlyContinue | Select-Object -First 1
        if ($wt) {
            # Flash the main window handle
            if ($wt.MainWindowHandle -ne [IntPtr]::Zero) {
                [WindowFlash]::Flash($wt.MainWindowHandle)
            }
        }
    ' &>/dev/null &
    notified=true
fi

# 2. Linux desktop: notify-send for a proper desktop notification
if ! $notified && has_cmd notify-send; then
    notify-send --urgency=normal "pling" "$MESSAGE" &>/dev/null &
    notified=true
fi

# 3. Linux X11: set urgency hint on the terminal window
if ! $notified && has_cmd xdotool; then
    wid=$(xdotool getactivewindow 2>/dev/null || true)
    if [[ -n "$wid" ]]; then
        xdotool set_window --urgency 1 "$wid" 2>/dev/null || true
        notified=true
    fi
fi

# 4. macOS: bounce the dock icon and show a notification
if ! $notified && [[ "$(uname)" == "Darwin" ]]; then
    if has_cmd osascript; then
        osascript -e "display notification \"$MESSAGE\" with title \"pling\"" &>/dev/null &
        notified=true
    fi
fi

# 5. Fallback: BEL character (works in some terminals)
if ! $notified; then
    printf "\a"
fi

# ─── Play notification sound ────────────────────────────────────────────────

if [[ -n "$SOUND" ]]; then
    # Resolve WSL path to Windows path if needed
    if is_wsl && has_cmd powershell.exe; then
        if [[ "$SOUND" == /* ]]; then
            WIN_SOUND=$(wslpath -w "$SOUND" 2>/dev/null || echo "$SOUND")
        else
            WIN_SOUND="$SOUND"
        fi
        powershell.exe -NoProfile -Command "
            Add-Type -AssemblyName PresentationCore
            \$player = New-Object System.Windows.Media.MediaPlayer
            \$player.Open([Uri]'$WIN_SOUND')
            \$player.Play()
            Start-Sleep -Milliseconds 3000
        " &>/dev/null &
    elif has_cmd paplay; then
        paplay "$SOUND" &>/dev/null &
    elif has_cmd aplay; then
        aplay "$SOUND" &>/dev/null &
    elif has_cmd afplay; then
        afplay "$SOUND" &>/dev/null &
    elif has_cmd mpv; then
        mpv --no-video --really-quiet "$SOUND" &>/dev/null &
    fi
fi

# Wait for background jobs to finish
wait 2>/dev/null || true

exit "$CMD_EXIT"
